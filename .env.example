# ==== Meta WhatsApp Cloud API ====
# Geçici token (API Setup > "Generate access token") — 24 saat geçerli.
# Kalıcı için ileride System User token üreteceğiz.
WHATSAPP_TOKEN=buraya_meta_access_token

# API Setup ekranındaki "Phone number ID"
PHONE_NUMBER_ID=1138922085977356

# Webhook doğrulama için kendi belirlediğin gizli kelime.
# Meta panelinde webhook bağlarken aynısını gireceksin.
VERIFY_TOKEN=otel-bot-dogrulama-2026

# ==== Gemini (Google) ====
# aistudio.google.com > "Get API key" (ücretsiz kotası var)
GEMINI_API_KEY=buraya_gemini_api_anahtari

# Model seçimi (ÜCRETSIZ kota uyarısı):
#   gemini-2.5-flash-lite  -> ücretsizde ~1000 istek/gün (VARSAYILAN, otel botu için yeterli)
#   gemini-2.5-flash       -> ücretsizde sadece ~20 istek/gün (kotaya hızlı takılır!)
# Daha yüksek hacim için Gemini projesinde faturalandırma açılmalı (mesaj başı kuruşlar).
GEMINI_MODEL=gemini-2.5-flash-lite

# ==== Otel ====
HOTEL_NAME=Otelimiz

# ==== Görüşme kaydı + e-posta bildirimi ====
# Google Apps Script Web App URL'i (görüşmeleri Sheet'e yazar, aktarmada e-posta atar).
# Boş bırakılırsa loglama devre dışı kalır.
LOG_WEBHOOK_URL=

# ==== Sunucu ====
PORT=3000
GRAPH_VERSION=v22.0
