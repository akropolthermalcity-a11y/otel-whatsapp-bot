# ==== Meta WhatsApp Cloud API ====
# Geçici token (API Setup > "Generate access token") — 24 saat geçerli.
# Kalıcı için ileride System User token üreteceğiz.
WHATSAPP_TOKEN=buraya_meta_access_token

# API Setup ekranındaki "Phone number ID"
PHONE_NUMBER_ID=1138922085977356

# Webhook doğrulama için kendi belirlediğin gizli kelime.
# Meta panelinde webhook bağlarken aynısını gireceksin.
VERIFY_TOKEN=otel-bot-dogrulama-2026

# ==== Gemini (Google) ====
# aistudio.google.com > "Get API key" (ücretsiz kotası var)
GEMINI_API_KEY=buraya_gemini_api_anahtari

# Model seçimi:
#   gemini-2.5-flash       -> hızlı ve ucuz (varsayılan, müşteri hizmetine ideal)
#   gemini-2.5-flash-lite  -> daha da ucuz/hızlı, daha basit cevaplar
GEMINI_MODEL=gemini-2.5-flash

# ==== Otel ====
HOTEL_NAME=Otelimiz

# ==== Sunucu ====
PORT=3000
GRAPH_VERSION=v22.0
